// F1R3FLY border radius tokens.
{
	"radius": {
		"sm": { "$value": "0.25rem", "$type": "dimension" }, // 4px
		"md": { "$value": "0.375rem", "$type": "dimension" }, // 6px
		"lg": { "$value": "0.5rem", "$type": "dimension" }, // 8px
		"xl": { "$value": "0.75rem", "$type": "dimension" }, // 12px
		"pill": { "$value": "9999px", "$type": "dimension" } // Rounded capsule bars
	}
}
