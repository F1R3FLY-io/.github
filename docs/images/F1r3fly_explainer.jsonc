	"stages_by_speed": {
		"0.10x": [
			{
				"id": "stage_1_opening",
				"name": "Opening Frame",
				"short_name": "Intro",
				"start_time": 0,
				"end_time": 4,
				"color": "#f4b942",
				"narration": {
					"tone": "product explainer, deliberate opening",
					"pause_ms": 220,
					"text": "Firefly rethinks high-throughput systems by tracing the intellectual lineage from lambda calculus to provable concurrent infrastructure. This explainer follows that arc."
				}
			},
			{
				"id": "stage_2_lambda",
				"name": "Lambda Calculus Foundations",
				"short_name": "Lambda",
				"start_time": 4,
				"end_time": 12,
				"color": "#f4b942",
				"narration": {
					"tone": "product explainer, informative",
					"pause_ms": 220,
					"text": "Church and Turing formalized computation as sequential pure functions. Lambda calculus defines what is computable but assumes a single thread of control. It offers no model for concurrency, no distribution primitives, and no channel abstractions. This limitation shaped every architecture that followed."
				}
			},
			{
				"id": "stage_3_von_neumann",
				"name": "Von Neumann Bottleneck",
				"short_name": "Von Neumann",
				"start_time": 12,
				"end_time": 20,
				"color": "#d17e7e",
				"narration": {
					"tone": "product explainer, technical",
					"pause_ms": 220,
					"text": "Von Neumann architectures hardwired sequential execution into silicon. Traditional scaling replicates the same line: more cores, more servers, more shared-state coordination. The SISD to MIMD transition created race conditions, deadlock, and composition problems that operational tooling cannot fully resolve."
				}
			},
			{
				"id": "stage_4_dataflow",
				"name": "Dataflow Transition",
				"short_name": "Dataflow",
				"start_time": 20,
				"end_time": 30,
				"color": "#44bfbf",
				"narration": {
					"tone": "product explainer, technical",
					"pause_ms": 220,
					"text": "Dataflow architectures change control logic. Work is triggered by data availability rather than a rigid instruction pointer. Execution routes through adaptive compute graphs that match modern silicon and distributed runtime behavior."
				}
			},
			{
				"id": "stage_5_pi_rho",
				"name": "Pi/Rho Calculus: Messages in the Type System",
				"short_name": "Pi/Rho",
				"start_time": 30,
				"end_time": 40,
				"color": "#ad8fff",
				"narration": {
					"tone": "product explainer, technical depth",
					"pause_ms": 240,
					"text": "Milner's pi-calculus replaced shared state with message passing as the fundamental primitive. Rho-calculus takes this further: channels become first-class values inside the type system. Protocol behavior becomes type-visible, enabling explicit protocol modeling and stronger compile-time guarantees -- not external queues bolted on after the fact."
				}
			},
			{
				"id": "stage_6_correctness_bft",
				"name": "Correctness by Construction + BFT",
				"short_name": "Verify+BFT",
				"start_time": 40,
				"end_time": 51,
				"color": "#84d08d",
				"narration": {
					"tone": "product explainer, deep technical",
					"pause_ms": 240,
					"text": "Spatial behavioral typing supports compile-time checks for deadlock freedom, race freedom, protocol adherence, and linear resource constraints. Combined with Byzantine fault tolerant consensus and dataflow execution, this improves both correctness and throughput while sustaining performance under adversarial conditions."
				}
			},
			{
				"id": "stage_7_tools",
				"name": "Tools, Systems, Services",
				"short_name": "Close",
				"start_time": 51,
				"end_time": 60,
				"color": "#f4b942",
				"narration": {
					"tone": "product explainer, deliberate close",
					"pause_ms": 220,
					"text": "Firefly delivers this through tools, systems, and services for visual modeling, debugging, design, and deployment. The result is a practical move from ad-hoc concurrency to provable concurrent infrastructure for blockchains, AI pipelines, and distributed backends."
				}
			}
		],
		"0.25x": [
			{
				"id": "stage_1_lambda",
				"name": "Lambda Calculus Foundations",
				"short_name": "Lambda",
				"start_time": 0,
				"end_time": 5,
				"color": "#f4b942",
				"narration": {
					"tone": "product explainer, detailed opening",
					"pause_ms": 180,
					"text": "Lambda calculus established the theoretical foundations of computation. Church and Turing formalized computation as pure sequential functions operating on a single thread of control, with no model for concurrency or communication."
				}
			},
			{
				"id": "stage_2_von_neumann",
				"name": "Von Neumann Bottleneck",
				"short_name": "Von Neumann",
				"start_time": 5,
				"end_time": 15,
				"color": "#d17e7e",
				"narration": {
					"tone": "product explainer, detailed",
					"pause_ms": 180,
					"text": "Von Neumann architectures implemented this sequential model in hardware. Scaling meant replicating the same line: more cores, more servers, more shared-state coordination. The SISD to MIMD transition introduced race conditions, deadlock, and fragile composition as fundamental engineering challenges."
				}
			},
			{
				"id": "stage_3_pi_rho",
				"name": "Pi/Rho Calculus: Messages in the Type System",
				"short_name": "Pi/Rho",
				"start_time": 15,
				"end_time": 27,
				"color": "#ad8fff",
				"narration": {
					"tone": "product explainer, detailed technical",
					"pause_ms": 180,
					"text": "Milner's pi-calculus replaced shared state with message passing as the computational primitive. Rho-calculus embeds channels as first-class type-system values rather than external infrastructure. Protocols become visible and checkable at design time instead of runtime."
				}
			},
			{
				"id": "stage_4_correctness",
				"name": "Correctness by Construction",
				"short_name": "Verify",
				"start_time": 27,
				"end_time": 39,
				"color": "#84d08d",
				"narration": {
					"tone": "product explainer, detailed technical",
					"pause_ms": 180,
					"text": "Spatial behavioral typing enables compile-time verification of deadlock freedom, race freedom, protocol adherence, and linear resource constraints. This shifts concurrency engineering from reactive debugging toward proactive correctness."
				}
			},
			{
				"id": "stage_5_performance_bft",
				"name": "Performance + BFT",
				"short_name": "Perf+BFT",
				"start_time": 39,
				"end_time": 51,
				"color": "#6ccf8a",
				"narration": {
					"tone": "product explainer, detailed outcomes",
					"pause_ms": 180,
					"text": "Dataflow execution aligns with modern parallel silicon and sustains throughput under distributed coordination. Combined with Byzantine fault tolerance, the system maintains correctness even when nodes behave adversarially, approaching crash-fault-like efficiency."
				}
			},
			{
				"id": "stage_6_tools",
				"name": "Outcome and Call to Action",
				"short_name": "Close",
				"start_time": 51,
				"end_time": 60,
				"color": "#f4b942",
				"narration": {
					"tone": "product explainer, detailed close",
					"pause_ms": 180,
					"text": "Firefly provides tools, systems, and services to visually model, debug, design, and deploy message-first software. Move from ad-hoc concurrency to provable concurrent infrastructure."
				}
			}
		],
		"1x": [
			{
				"id": "stage_1_lambda",
				"name": "Lambda Calculus Foundations",
