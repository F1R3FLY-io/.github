#!/usr/bin/env bash
#
# pre-push hook - run checks before push
#
# Installation:
#   ./scripts/setup-hooks.sh
#   ./scripts/setup-hooks.sh --copy
#
# Environment:
#   QUICK=1            Skip build step (still runs typecheck + tests)
#   SKIP_TS_TESTS=1    Skip TypeScript unit tests
#   SKIP_TYPECHECK=1   Skip type checking
#   SKIP_BUILD=1       Skip build step
#

set -euo pipefail

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
NC='\033[0m'

REPO_ROOT="$(git rev-parse --show-toplevel)"

QUICK="${QUICK:-0}"
SKIP_TS_TESTS="${SKIP_TS_TESTS:-0}"
SKIP_TYPECHECK="${SKIP_TYPECHECK:-0}"
SKIP_BUILD="${SKIP_BUILD:-0}"

if [ -n "${CI:-}" ] || [ -n "${GITHUB_ACTIONS:-}" ]; then
	echo "Skipping pre-push checks in CI."
	exit 0
fi

# Read push refs from stdin and skip when there are no new commits.
has_new_commits=0
while IFS=' ' read -r _local_ref local_oid _remote_ref remote_oid; do
	zero="0000000000000000000000000000000000000000"
	if [ "${local_oid:-$zero}" != "${remote_oid:-$zero}" ] && [ "${local_oid:-$zero}" != "$zero" ]; then
		has_new_commits=1
	fi
done

if [ "$has_new_commits" -eq 0 ]; then
	echo -e "${CYAN}No new commits to push. Skipping pre-push checks.${NC}"
	exit 0
fi

if ! command -v pnpm >/dev/null 2>&1; then
	echo -e "${RED}pnpm is required for pre-push checks but was not found in PATH.${NC}"
	exit 1
fi

echo ""
echo -e "${CYAN}Running pre-push checks...${NC}"
echo "==========================="

if [ "$SKIP_TYPECHECK" != "1" ]; then
	echo -e "${CYAN}Typecheck:${NC} pnpm run typecheck"
	pnpm --dir "$REPO_ROOT" run typecheck
else
	echo -e "${YELLOW}SKIP:${NC} typecheck (SKIP_TYPECHECK=1)"
fi

if [ "$SKIP_TS_TESTS" != "1" ]; then
	echo -e "${CYAN}Unit tests:${NC} pnpm run test"
	pnpm --dir "$REPO_ROOT" run test
else
	echo -e "${YELLOW}SKIP:${NC} unit tests (SKIP_TS_TESTS=1)"
fi

if [ "$SKIP_BUILD" = "1" ] || [ "$QUICK" = "1" ]; then
	echo -e "${YELLOW}SKIP:${NC} build (SKIP_BUILD=1 or QUICK=1)"
else
	echo -e "${CYAN}Build:${NC} pnpm run build"
	pnpm --dir "$REPO_ROOT" run build
fi

echo ""
echo -e "${GREEN}Pre-push checks passed.${NC}"
